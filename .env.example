# ==========================================
# ADVANCED TRAVEL BOT - PLANTILLA DE ENTORNO
# (Copia este archivo localmente como .env y pon tus datos reales)
# ==========================================

# --- Red y Evasión (1.1.1.1 WARP / Proxies) ---
# Puerto local donde escucha la app 1.1.1.1 u otro proxy proxy
WARP_PROXY_URL="socks5://127.0.0.1:XXXXX"

# --- Comportamiento del Motor Python ---
# Semáforo de velocidad: pausa humana entre peticiones (en segundos)
SPEED_SEMAPHORE_DELAY=2.5

# Intentos máximos del decorador de auto-curación ante un bloqueo
MAX_RETRIES=3

# Activar el salto automático a dominios espejo (ej. .com a .es) si hay bloqueo 403
ENABLE_MIRROR_ROUTING=True

# --- Gestión de Memoria (Pass-through pipe) ---
# Límite de tamaño de chunk en KB para purgar la RAM y mantener el consumo bajo
CHUNK_SIZE_KB=64
